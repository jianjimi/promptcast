# 复制为 .env 后按需修改。
DATABASE_URL="postgresql://promptcast:promptcast@localhost:5432/promptcast?schema=public"
# JWT_SECRET 必须改成强随机值再用于任何非本地环境（HS256 对称密钥，泄漏=任何人可伪造他人 token）。
# 生成： openssl rand -hex 32   或   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="dev-access-secret-change-me"
ACCESS_TOKEN_TTL="900s"
REFRESH_TOKEN_TTL_DAYS="30"
PORT="3000"
# 生产请设 NODE_ENV=production（此时若 JWT_SECRET 仍是 dev 默认值，服务会拒绝启动）。
